<Application x:Class="Ruki.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Nessuno StartupUri: la finestra iniziale (l'overlay) viene creata e mostrata
        a mano in App.xaml.cs, dopo aver costruito il container di dependency injection.
    -->
    <Application.Resources>
        <!-- ============================================================================
             Tema chiaro condiviso da tutte le finestre di Ruki: un solo punto di verità
             per i colori, così overlay, chat, impostazioni e debug restano coerenti.
             ============================================================================ -->

        <SolidColorBrush x:Key="RukiBackground" Color="#F5F6F8" />   <!-- sfondo finestre -->
        <SolidColorBrush x:Key="RukiSurface" Color="#FFFFFFFF" />    <!-- pannelli/bolle -->
        <SolidColorBrush x:Key="RukiText" Color="#202124" />         <!-- testo principale -->
        <SolidColorBrush x:Key="RukiSubtleText" Color="#6B7280" />   <!-- testo secondario -->
        <SolidColorBrush x:Key="RukiAccent" Color="#2B7CFF" />       <!-- blu d'accento -->
        <SolidColorBrush x:Key="RukiBorder" Color="#E2E4E8" />       <!-- bordi sottili -->
        <SolidColorBrush x:Key="RukiHover" Color="#14000000" />      <!-- hover su tema chiaro -->
        <SolidColorBrush x:Key="RukiPressed" Color="#22000000" />    <!-- pressione -->
        <SolidColorBrush x:Key="RukiDanger" Color="#E5484D" />       <!-- stop/errore -->

        <!-- Contorno "arcobaleno" (oro, verde, blu, rosso): dà un tocco di colore all'overlay
             e lo rende riconoscibile rispetto allo sfondo del desktop. -->
        <LinearGradientBrush x:Key="RukiRainbow" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F5C518" Offset="0.0" />
            <GradientStop Color="#34C759" Offset="0.35" />
            <GradientStop Color="#2B7CFF" Offset="0.7" />
            <GradientStop Color="#FF3B30" Offset="1.0" />
        </LinearGradientBrush>
    </Application.Resources>
</Application>
