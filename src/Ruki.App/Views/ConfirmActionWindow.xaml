<Window x:Class="Ruki.App.Views.ConfirmActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Ruki.App.Localization"
        Title="Ruki"
        Icon="/Assets/Logo.png"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen">

    <!-- Dialogo di conferma azione rischiosa: sempre in primo piano (Topmost), riconoscibile dal
         bordo arcobaleno come le altre finestre di Ruki. -->
    <Border CornerRadius="12" BorderBrush="{StaticResource RukiRainbow}" BorderThickness="2" Padding="18">
        <Border.Background>
            <SolidColorBrush Color="#FFFFFF" />
        </Border.Background>
        <StackPanel MaxWidth="420">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="&#x26A0;" FontSize="16" Foreground="#E08600" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="{loc:Loc Confirm_Title}" FontWeight="SemiBold" FontSize="14"
                           Foreground="{StaticResource RukiText}" VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock x:Name="MessageText" TextWrapping="Wrap" Foreground="{StaticResource RukiText}"
                       FontSize="13" Margin="0,0,0,16" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="NoButton" Content="{loc:Loc Common_No}" MinWidth="84" Padding="14,6"
                        Margin="0,0,8,0" Click="No_Click" IsCancel="True" />
                <Button Content="{loc:Loc Common_Yes}" MinWidth="84" Padding="14,6" Click="Yes_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
