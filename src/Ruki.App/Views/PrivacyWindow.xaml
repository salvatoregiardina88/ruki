<Window x:Class="Ruki.App.Views.PrivacyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Ruki.App.Localization"
        Title="{loc:Loc Title_Privacy}"
        Icon="/Assets/Logo.png"
        Width="660" Height="640"
        Background="{StaticResource RukiBackground}"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="PrivacyText" Grid.Row="0"
                 IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 FontSize="12.5" Padding="12"
                 Background="{StaticResource RukiSurface}" Foreground="{StaticResource RukiText}"
                 BorderBrush="{StaticResource RukiBorder}" BorderThickness="1" />

        <Button Grid.Row="1" Content="{loc:Loc Common_Close}" HorizontalAlignment="Right"
                Margin="0,12,0,0" Padding="18,6" IsCancel="True" Click="OnCloseClick" />
    </Grid>
</Window>
