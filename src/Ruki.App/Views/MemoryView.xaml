<UserControl x:Class="Ruki.App.Views.MemoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Ruki.App.Localization">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Barra dei comandi -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="{loc:Loc Memory_Refresh}" Command="{Binding RefreshCommand}" Margin="0,0,6,0" Padding="8,3" />
            <Button Content="{loc:Loc Memory_AddCategory}" Command="{Binding AddCategoryCommand}" Margin="0,0,6,0" Padding="8,3" />
            <Button Content="{loc:Loc Memory_AddMemory}" Command="{Binding AddMemoryCommand}" Margin="0,0,6,0" Padding="8,3" />
            <Button Content="{loc:Loc Memory_Delete}" Command="{Binding DeleteCommand}" Margin="0,0,6,0" Padding="8,3" />
            <!-- Archivia/Riattiva in base allo stato del nodo selezionato (testo localizzato). -->
            <Button Command="{Binding ToggleObsoleteCommand}" Margin="0,0,6,0" Padding="8,3"
                    ToolTip="{loc:Loc Memory_ToggleTip}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="{loc:Loc Memory_Archive}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedIsObsolete}" Value="True">
                                <Setter Property="Content" Value="{loc:Loc Memory_Reactivate}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="{loc:Loc Memory_Maintenance}" Command="{Binding RunMaintenanceCommand}" Padding="8,3"
                    ToolTip="{loc:Loc Memory_MaintenanceTip}" />
        </StackPanel>

        <!-- Albero della memoria -->
        <TreeView x:Name="Tree" Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                  ItemsSource="{Binding Roots}"
                  SelectedItemChanged="OnSelectedItemChanged">
            <!-- Espansione e selezione bindate al nodo: si conservano quando l'albero si ricostruisce. -->
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Glyph}" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding Title}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <!-- Le memorie archiviate appaiono in grigio corsivo. -->
                                        <DataTrigger Binding="{Binding IsObsolete}" Value="True">
                                            <Setter Property="Foreground" Value="Gray" />
                                            <Setter Property="FontStyle" Value="Italic" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- Editor del nodo selezionato -->
        <StackPanel Grid.Row="1" Grid.Column="1" IsEnabled="{Binding HasSelection}">
            <TextBlock Text="{loc:Loc Memory_Title}" FontWeight="SemiBold" Margin="0,2,0,2" />
            <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="{loc:Loc Memory_Summary}" FontWeight="SemiBold" Margin="0,10,0,2" />
            <!-- Altezza fissa con barra di scorrimento: non cresce col testo (così Salva resta visibile). -->
            <TextBox Text="{Binding EditSummary, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap" AcceptsReturn="True" Height="56"
                     VerticalScrollBarVisibility="Auto" />

            <TextBlock Text="{loc:Loc Memory_Content}" FontWeight="SemiBold" Margin="0,10,0,2"
                       Visibility="{Binding IsMemorySelected, Converter={StaticResource BoolToVis}}" />
            <TextBox Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap" AcceptsReturn="True" Height="200"
                     VerticalScrollBarVisibility="Auto"
                     Visibility="{Binding IsMemorySelected, Converter={StaticResource BoolToVis}}" />

            <Button Content="{loc:Loc Common_Save}" Command="{Binding SaveCommand}"
                    HorizontalAlignment="Left" Margin="0,10,0,0" Padding="16,4" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="#107C10" Margin="0,8,0,0" />
        </StackPanel>

        <!-- Footer: quando è girata l'ultima volta la manutenzione (automatica o manuale). -->
        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding LastMaintenanceText}"
                   Foreground="{StaticResource RukiSubtleText}" FontSize="11" Margin="0,8,0,0" />
    </Grid>
</UserControl>
