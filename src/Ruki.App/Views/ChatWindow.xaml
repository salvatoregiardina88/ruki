<Window x:Class="Ruki.App.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Ruki.App.Localization"
        Title="{loc:Loc Title_Chat}"
        Icon="/Assets/Logo.png"
        Width="400" Height="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual">

    <!--
        Chat come overlay: scheda chiara fluttuante, senza bordo di sistema, posizionata appena
        sopra la barra dell'overlay (vedi WindowService). Si sposta trascinando l'intestazione.
    -->

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border Margin="12" CornerRadius="12"
            Background="{StaticResource RukiSurface}"
            BorderBrush="{StaticResource RukiBorder}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.22" Color="#000000" />
        </Border.Effect>

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Intestazione: titolo + X. Trascinabile per spostare la finestra. -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown" Margin="2,0,0,4">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/Logo.png" Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="Ruki" FontWeight="SemiBold" Foreground="{StaticResource RukiText}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="20" Height="20" Padding="0" Cursor="Hand"
                        Background="Transparent" BorderThickness="0"
                        Click="Close_Click" ToolTip="{loc:Loc Overlay_CloseTip}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="10">
                                <TextBlock Text="✕" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource RukiSubtleText}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource RukiHover}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Elenco messaggi -->
            <ScrollViewer x:Name="MessagesScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Bolla: a destra/blu se è dell'utente, a sinistra/grigia per l'assistente,
                                 rossa per gli errori. Colori e allineamento via DataTrigger sui booleani. -->
                            <Border Margin="6,4" Padding="10,7" CornerRadius="10" MaxWidth="300">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#EEEFF1" />
                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource RukiAccent}" />
                                                <Setter Property="HorizontalAlignment" Value="Right" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                <Setter Property="Background" Value="#FDE7E9" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource RukiText}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                                    <Setter Property="Foreground" Value="#B00020" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Indicatore "sta scrivendo" -->
            <TextBlock Grid.Row="2" Margin="12,2" Foreground="{StaticResource RukiSubtleText}" FontStyle="Italic"
                       Text="{loc:Loc Chat_Typing}"
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />

            <!-- Riga di input -->
            <Grid Grid.Row="3" Margin="6,8,6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Cresce in altezza col testo (a capo automatico) fino a ~5 righe, poi scorre. -->
                <TextBox Grid.Column="0" Padding="8" VerticalContentAlignment="Top"
                         TextWrapping="Wrap" MaxHeight="118" VerticalScrollBarVisibility="Auto"
                         Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <!-- Invio per inviare il messaggio. -->
                        <KeyBinding Key="Return" Command="{Binding SendCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="1" Content="{loc:Loc Chat_Send}" Margin="8,0,0,0" Padding="18,6"
                        VerticalAlignment="Bottom" Command="{Binding SendCommand}" />
            </Grid>
        </Grid>
    </Border>
</Window>
